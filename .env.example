# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001
MODEL_REGISTRY_NAME=claims_denial_model

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# Airflow
AIRFLOW_SECRET_KEY=claims-platform-secret
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Data
DATA_DIR=./data
CLAIMS_DATA_PATH=./data/synthetic_claims.csv
N_SYNTHETIC_CLAIMS=50000

# Model
MODEL_PATH=./models/best_model.pkl
PREDICTION_THRESHOLD=0.5
